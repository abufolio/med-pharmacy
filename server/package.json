{
  "name": "pharmacy-cashback-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Universal Pharmacy Cashback Platform - Backend",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "nest start api --watch",
    "dev:worker": "nest start worker --watch",
    "dev:bot": "nest start bot --watch",
    "build": "nest build",
    "build:bot": "nest build bot",
    "prisma:generate": "cd packages/database && npx prisma generate",
    "prisma:migrate": "cd packages/database && npx prisma migrate dev",
    "prisma:studio": "cd packages/database && npx prisma studio",
    "lint": "eslint \"{apps,packages}/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:auth": "jest apps/api/src/modules/auth",
    "test:transactions": "jest apps/api/src/modules/transactions"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.0.0",
    "@prisma/client": "^6.19.3",
    "@sentry/nestjs": "^10.65.0",
    "@sentry/node": "^10.65.0",
    "@willsoto/nestjs-prometheus": "^6.1.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.0.0",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "grammy": "^1.44.0",
    "ioredis": "^5.4.0",
    "nanoid": "^5.0.0",
    "nestjs-pino": "^4.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.0",
    "pino": "^10.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/bcryptjs": "^2.4.0",
    "@types/jest": "^29.0.0",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.0.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "prisma": "^6.5.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
