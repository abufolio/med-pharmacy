// ──────────────────────────────────────────────
// Universal Pharmacy Cashback Platform
// Bot Prisma Schema — mirrors server schema
// ──────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// Users (Customers)
// ──────────────────────────────────────────────
enum UserStatus {
  PENDING_CARD
  ACTIVE
  BLOCKED
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  firstName    String     @map("first_name") @db.VarChar(80)
  lastName     String     @map("last_name") @db.VarChar(80)
  phone        String     @unique @db.VarChar(20)
  telegramId    BigInt?   @unique @map("telegram_id")
  language     String     @default("uz") @db.VarChar(5)
  status       UserStatus @default(PENDING_CARD)
  passwordHash String?    @map("password_hash") @db.VarChar(255)
  address      String?    @db.VarChar(300)
  addressLat   Decimal?   @map("address_lat") @db.Decimal(10, 7)
  addressLng   Decimal?   @map("address_lng") @db.Decimal(10, 7)
  deletedAt    DateTime?  @map("deleted_at")

  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  // Relations
  cardAssignments CardAssignment[]
  transactions    Transaction[]
  cashbacks       Cashback[]
  wallet          Wallet?
  withdrawRequests WithdrawRequest[]
  notifications   Notification[]
  referralsMade   Referral[]       @relation("referrer")
  referralsUsed   Referral?        @relation("referred")
  promoRedemptions PromoRedemption[]
  activityLogs    ActivityLog[]

  @@index([phone])
  @@index([telegramId])
  @@index([status])
  @@index([createdAt])
  @@map("users")
}

// ──────────────────────────────────────────────
// Cards & Card Assignments (NFC)
// ──────────────────────────────────────────────
enum CardStatus {
  UNASSIGNED
  ACTIVE
  BLOCKED
  REPLACED
}

model Card {
  id          String           @id @default(uuid()) @db.Uuid
  uid         String           @unique @db.VarChar(32)
  status      CardStatus       @default(UNASSIGNED)
  deletedAt   DateTime?        @map("deleted_at")

  issuedAt    DateTime         @default(now()) @map("issued_at")
  assignments CardAssignment[]

  @@index([status])
  @@index([issuedAt])
  @@map("cards")
}

enum CardAssignmentStatus {
  ACTIVE
  UNASSIGNED
}

model CardAssignment {
  id           String               @id @default(uuid()) @db.Uuid
  cardId       String               @map("card_id") @db.Uuid
  card         Card                 @relation(fields: [cardId], references: [id], onDelete: Restrict)
  userId       String               @map("user_id") @db.Uuid
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  status       CardAssignmentStatus @default(ACTIVE)
  assignedAt   DateTime             @default(now()) @map("assigned_at")
  unassignedAt DateTime?            @map("unassigned_at")

  @@unique([cardId, status])
  @@index([userId])
  @@index([cardId])
  @@index([assignedAt])
  @@map("card_assignments")
}

// ──────────────────────────────────────────────
// Transactions (Financial — NEVER soft delete)
// ──────────────────────────────────────────────
enum TransactionStatus {
  PENDING
  COMPLETED
  REVERSED
  FAILED
  FLAGGED
}

model Transaction {
  id          String            @id @default(uuid()) @db.Uuid
  userId      String            @map("user_id") @db.Uuid
  user        User              @relation(fields: [userId], references: [id], onDelete: Restrict)
  pharmacyId   String            @map("pharmacy_id") @db.Uuid
  amount      Decimal           @db.Decimal(14, 2)
  status      TransactionStatus @default(PENDING)
  createdAt   DateTime          @default(now()) @map("created_at")

  cashbacks Cashback[]

  @@index([userId])
  @@index([pharmacyId])
  @@index([status])
  @@index([createdAt])
  @@map("transactions")
}

// ──────────────────────────────────────────────
// Cashbacks
// ──────────────────────────────────────────────
enum CashbackStatus {
  ACTIVE
  ROLLED_BACK
  EXPIRED
  FROZEN
}

model Cashback {
  id            String         @id @default(uuid()) @db.Uuid
  transactionId String         @unique @map("transaction_id") @db.Uuid
  transaction   Transaction    @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  userId        String         @map("user_id") @db.Uuid
  user          User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  amount        Decimal        @db.Decimal(14, 2)
  status        CashbackStatus @default(ACTIVE)
  expiresAt     DateTime?      @map("expires_at")
  createdAt     DateTime       @default(now()) @map("created_at")

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("cashbacks")
}

// ──────────────────────────────────────────────
// Wallets
// ──────────────────────────────────────────────
model Wallet {
  id        String            @id @default(uuid()) @db.Uuid
  userId    String            @unique @map("user_id") @db.Uuid
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance   Decimal           @default(0) @db.Decimal(14, 2)
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  transactions WalletTransaction[]

  @@index([createdAt])
  @@map("wallets")
}

enum WalletTransactionType {
  CREDIT
  DEBIT
}

model WalletTransaction {
  id            String              @id @default(uuid()) @db.Uuid
  walletId      String              @map("wallet_id") @db.Uuid
  wallet        Wallet              @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type          WalletTransactionType
  amount        Decimal             @db.Decimal(14, 2)
  referenceType String              @map("reference_type") @db.VarChar(60)
  referenceId   String?             @map("reference_id") @db.Uuid
  description   String?             @db.VarChar(255)
  createdAt     DateTime            @default(now()) @map("created_at")

  @@index([walletId])
  @@index([referenceType, referenceId])
  @@index([createdAt])
  @@map("wallet_transactions")
}

// ──────────────────────────────────────────────
// Withdraw Requests
// ──────────────────────────────────────────────
enum WithdrawRequestStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

model WithdrawRequest {
  id         String              @id @default(uuid()) @db.Uuid
  userId     String              @map("user_id") @db.Uuid
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount     Decimal             @db.Decimal(14, 2)
  status     WithdrawRequestStatus @default(PENDING)
  reviewedBy String?             @map("reviewed_by") @db.Uuid
  createdAt  DateTime            @default(now()) @map("created_at")
  reviewedAt DateTime?           @map("reviewed_at")

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("withdraw_requests")
}

// ──────────────────────────────────────────────
// Notifications
// ──────────────────────────────────────────────
model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   @db.VarChar(50)
  message   String   @db.Text
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ──────────────────────────────────────────────
// Referrals
// ──────────────────────────────────────────────
enum ReferralStatus {
  PENDING
  COMPLETED
}

model Referral {
  id           String  @id @default(uuid()) @db.Uuid
  referrerId   String  @map("referrer_id") @db.Uuid
  referrer     User    @relation("referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referredId   String  @unique @map("referred_id") @db.Uuid
  referred     User    @relation("referred", fields: [referredId], references: [id], onDelete: Cascade)
  status       ReferralStatus @default(PENDING)
  bonusAmount  Decimal @default(0) @map("bonus_amount") @db.Decimal(14, 2)
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([referrerId])
  @@index([status])
  @@index([createdAt])
  @@map("referrals")
}

// ──────────────────────────────────────────────
// Promo Codes
// ──────────────────────────────────────────────
enum PromoCodeType {
  PERCENT
  FIXED
}

model PromoCode {
  id         String           @id @default(uuid()) @db.Uuid
  code       String           @unique @db.VarChar(50)
  type       PromoCodeType
  value      Decimal          @db.Decimal(10, 2)
  usageLimit Int              @default(0) @map("usage_limit")
  usedCount  Int              @default(0) @map("used_count")
  validFrom  DateTime?        @map("valid_from")
  validTo    DateTime?        @map("valid_to")
  isActive   Boolean          @default(true) @map("is_active")
  deletedAt  DateTime?        @map("deleted_at")

  createdAt  DateTime         @default(now()) @map("created_at")
  redemptions PromoRedemption[]

  @@index([code])
  @@index([isActive])
  @@index([createdAt])
  @@map("promo_codes")
}

model PromoRedemption {
  id          String   @id @default(uuid()) @db.Uuid
  promoCodeId String   @map("promo_code_id") @db.Uuid
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  userId      String   @map("user_id") @db.Uuid
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  redeemedAt  DateTime @default(now()) @map("redeemed_at")

  @@unique([promoCodeId, userId])
  @@index([userId])
  @@index([redeemedAt])
  @@map("promo_redemptions")
}

// ──────────────────────────────────────────────
// Activity Logs (user-facing)
// ──────────────────────────────────────────────
model ActivityLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String   @db.VarChar(100)
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("activity_logs")
}
